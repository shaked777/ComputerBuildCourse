# ── Live leaderboard (optional) ──────────────────────────────
# Copy this file to `.env`, fill in the two values from your
# Supabase project (Project Settings → API), then restart `npm run dev`.
# Without these, the app runs fine with a local demo leaderboard.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
